# Database (Supabase)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres"

# NextAuth
AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Token encryption (AES-256-GCM) for OAuth tokens stored in DB.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# IMPORTANT: once set, do NOT change it in production — existing encrypted tokens become unreadable.
ENCRYPTION_KEY=""

# Google OAuth (for login + Calendar sync)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft OAuth (for login + Outlook sync)
# https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# GitHub OAuth (for login)
# https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Apple OAuth (for login)
# https://developer.apple.com/account/resources/identifiers
APPLE_ID=""
APPLE_SECRET=""

# Enterprise SSO (OIDC) - Works with Okta, Auth0, OneLogin, Azure AD, etc.
# Configure these for enterprise single sign-on
SSO_CLIENT_ID=""
SSO_CLIENT_SECRET=""
SSO_ISSUER=""  # e.g., https://your-company.okta.com, https://your-tenant.auth0.com
SSO_PROVIDER_NAME="SSO Entreprise"  # Display name on login button

# Email (Resend for magic links)
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"

# ---------------------------------------------------------------------------
# Row Level Security (defense-in-depth) — see README "RLS rollout"
# ---------------------------------------------------------------------------
# Phase A (default): leave these empty. The migration enables RLS but the app
# connects as `postgres` (BYPASSRLS on Supabase), so nothing changes for Prisma
# while anon/authenticated/direct access is now policy-protected.
#
# Phase B (enforce RLS on the Prisma path):
#   1. Create a login password for the `app_user` role created by the migration.
#   2. Point DATABASE_URL at app_user (NOBYPASSRLS) instead of postgres.
#   3. Set ADMIN_DATABASE_URL to the owner/postgres connection (cron + NextAuth
#      adapter use this via `dbAdmin`).
#   4. Wrap user-scoped Prisma work in withRls() (src/infrastructure/db/rls.ts).
# ADMIN_DATABASE_URL=""

# Integration tests only: a throwaway Postgres connection (e.g. a Supabase dev
# project or CI `postgres` service) used by tests/integration/*. Never point at
# production. When unset, the RLS integration tests are skipped.
# TEST_DATABASE_URL=""

# Legacy NextAuth v4 names are still accepted via a shim (see auth/config.ts),
# but AUTH_SECRET / AUTH_URL above are the canonical names — prefer them.

# ---------------------------------------------------------------------------
# Calendar / task integration providers — see docs/INTEGRATIONS.md
# ---------------------------------------------------------------------------
# ICS (file upload + subscribe-by-URL) and CalDAV (Apple Calendar) need NO env
# vars here — those credentials are entered by the user in the UI.
#
# The OAuth providers below require an app registered with each service. The
# OAuth flows are scaffolding-pending; until both vars of a provider are set,
# the provider shows "Configuration requise" in the sync center.

# Notion OAuth — https://www.notion.so/my-integrations
NOTION_CLIENT_ID=""
NOTION_CLIENT_SECRET=""

# Todoist OAuth — https://developer.todoist.com/appconsole.html
TODOIST_CLIENT_ID=""
TODOIST_CLIENT_SECRET=""

# TickTick OAuth — https://developer.ticktick.com/manage
TICKTICK_CLIENT_ID=""
TICKTICK_CLIENT_SECRET=""
