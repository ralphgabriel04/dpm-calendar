# Database (Supabase)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres"

# NextAuth
AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Token encryption (AES-256-GCM) for OAuth tokens stored in DB.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# IMPORTANT: once set, do NOT change it in production — existing encrypted tokens become unreadable.
ENCRYPTION_KEY=""

# Google OAuth (for login + Calendar sync)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft OAuth (for login + Outlook sync)
# https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# GitHub OAuth (for login)
# https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Apple OAuth (for login)
# https://developer.apple.com/account/resources/identifiers
APPLE_ID=""
APPLE_SECRET=""

# Enterprise SSO (OIDC) - Works with Okta, Auth0, OneLogin, Azure AD, etc.
# Configure these for enterprise single sign-on
SSO_CLIENT_ID=""
SSO_CLIENT_SECRET=""
SSO_ISSUER=""  # e.g., https://your-company.okta.com, https://your-tenant.auth0.com
SSO_PROVIDER_NAME="SSO Entreprise"  # Display name on login button

# Email (Resend for magic links)
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"
